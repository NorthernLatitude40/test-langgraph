@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix kiwi: <http://kiwiexperience.com/ontology/> .

# ==========================================
# 地點實例定義
# ==========================================
kiwi:Auckland a kiwi:City ; rdfs:label "Auckland" .
kiwi:Queenstown a kiwi:City ; rdfs:label "Queenstown" .
kiwi:Wellington a kiwi:City ; rdfs:label "Wellington" .
kiwi:Christchurch a kiwi:City ; rdfs:label "Christchurch" .
kiwi:Anywhere a kiwi:City ; rdfs:label "Anywhere" .

# ==========================================
# 網頁 12 筆特惠行程數據
# ==========================================

# 1. BUZZY BEE
kiwi:Deal_BuzzyBee a kiwi:HopOnHopOffDeal ;
    rdfs:label "Buzzy Bee" ;
    kiwi:startsFrom kiwi:Auckland ;
    kiwi:endsAt kiwi:Queenstown ;
    kiwi:durationDays 13 ;
    kiwi:discountPercent 30 ;
    kiwi:priceNZD 986.00 .

